generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  HOST
  GUEST
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}
model User {
  id                String    @id @default(uuid())
  name              String
  email             String    @unique
  username          String    @unique
  phone             String
  role              Role      @default(GUEST)
  avatar            String?
  avatarPublicId    String?
  bio               String?
  password          String
  resetToken        String?
  resetTokenExpiry  DateTime?
  updatedAt         DateTime  @updatedAt
  listings          Listing[]
  bookings          Booking[]
  reviews           Review[]
}

model Listing {
  id            String         @id @default(uuid())
  title         String
  description   String
  location      String
  pricePerNight Float
  guests        Int
  type          String
  amenities     String[]
  rating        Float?
  hostId        String
  host          User           @relation(fields: [hostId], references: [id])
  bookings      Booking[]
  photos        ListingPhoto[]
  reviews       Review[]

  @@index([location])
  @@index([pricePerNight])
  @@index([type])
  @@index([hostId])
  @@index([type, location])
}

model ListingPhoto {
  id        String  @id @default(uuid())
  url       String
  publicId  String
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id])
}

model Booking {
  id         String        @id @default(uuid())
  listingId  String
  guestId    String
  checkIn    DateTime
  checkOut   DateTime
  totalPrice Float
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  listing    Listing       @relation(fields: [listingId], references: [id])
  guest      User          @relation(fields: [guestId], references: [id])

  @@index([guestId])
  @@index([listingId])
  @@index([listingId, checkIn, checkOut])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String
  userId    String
  listingId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])

  @@index([userId])
  @@index([listingId])
}